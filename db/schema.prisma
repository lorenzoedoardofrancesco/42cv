datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts           Account[]
  sessions           Session[]
  projectGithubLinks ProjectGithubLink[]

  ftSchoolVerified Boolean @default(false)
  extended42Data   Json?

  isDisplayEmail              Boolean @default(true)
  isDisplayName               Boolean @default(true)
  isDisplayPhoto              Boolean @default(false)
  isDisplayProjectCount       Boolean @default(true)
  isPublicProfile             Boolean @default(false)
  isDisplayOutstandingVotes   Boolean @default(true)
  selectedAchievementIds      Int[]   @default([])
  githubUrl                   String?
  linkedinUrl                 String?
  address                     String?
  phone                       String?
  defaultDarkMode             Boolean @default(false)
  isDisplayCampusCohortRank   Boolean @default(false)
  isDisplayCohortRank         Boolean @default(false)
  isDisplayAllTimeRank        Boolean @default(false)
  bio                         String?
}

model ProjectDescription {
  slug             String   @id
  description      String?
  correctionNumber Int?
  checkedAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TeamStat {
  teamId           Int      @id
  totalEvals       Int      @default(0)
  outstandingCount Int      @default(0)
  checkedAt        DateTime @default(now())
}

model BlockedLoginsCache {
  id        Int      @id @default(1) // singleton row
  logins    String[] @default([])
  updatedAt DateTime @updatedAt
}

model RankingCache {
  login             String   @id
  level             Float?
  poolYear          String?
  campusId          Int?
  allTimeRank       Int?
  allTimeTotal      Int?
  cohortRank        Int?
  cohortTotal       Int?
  campusCohortRank  Int?
  campusCohortTotal Int?
  checkedAt         DateTime @default(now())
}

model CronCheckpoint {
  key     String   @id
  data    Json
  savedAt DateTime @updatedAt
}

model ProjectGithubLink {
  userId      String
  projectSlug String
  githubUrl   String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, projectSlug])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
