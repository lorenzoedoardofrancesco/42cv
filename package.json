{
  "name": "42cv",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate --schema=./db/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./db/schema.prisma --skip-seed",
    "db:reset": "prisma migrate reset --schema=./db/schema.prisma --skip-seed",
    "db:push": "prisma db push --schema=./db/schema.prisma",
    "db:seed": "npx prisma db seed",
    "db:studio": "prisma studio --schema=./db/schema.prisma",
    "postinstall": "prisma generate --schema=./db/schema.prisma"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} db/seed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.13.0",
    "@icons-pack/react-simple-icons": "^9.7.0",
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.0",
    "cloudinary": "^2.9.0",
    "lodash-es": "^4.17.21",
    "next": "^14.2.0",
    "next-auth": "^4.24.0",
    "node-cache": "^5.1.2",
    "p-queue": "6.6.2",
    "react": "^18.3.0",
    "react-copy-to-clipboard": "^5.1.0",
    "react-dom": "^18.3.0",
    "react-icons": "^5.3.0",
    "string-pixel-width": "^1.10.0"
  },
  "devDependencies": {
    "@rvxlab/tailwind-plugin-ios-full-height": "^1.1.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-copy-to-clipboard": "^5.0.7",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.6.0"
  }
}
